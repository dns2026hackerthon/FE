# Kakao Maps JavaScript 키 (지도뷰 실제 지도 렌더링용)
# https://developers.kakao.com → 애플리케이션 → JavaScript 키
# 값이 없으면 데모용 플레이스홀더 지도로 동작합니다.
NEXT_PUBLIC_KAKAO_MAP_KEY=

# 백엔드 API base URL (서버 연동 시 설정, 예: https://api.example.com)
# 비어 있으면 목업(localStorage) 데이터로 동작합니다.
# 기대하는 REST 계약은 src/api/http.ts 상단 주석 참고.
NEXT_PUBLIC_API_BASE_URL=
